<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kelola Setelan Aplikasi"
            android:textSize="22sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/et_contact_email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Email Kontak Admin"
            android:inputType="textEmailAddress"
            android:layout_marginTop="16dp" />

        <EditText
            android:id="@+id/et_contact_phone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Telepon / WhatsApp"
            android:inputType="phone"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_social_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URL Medsos"
            android:inputType="textUri"
            android:layout_marginTop="8dp" />

        <EditText
            android:id="@+id/et_other_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URL Fitur Lainnya"
            android:inputType="textUri"
            android:layout_marginTop="8dp" />

        <Button
            android:id="@+id/btn_save_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Simpan Setelan"
            android:layout_marginTop="16dp" />
    </LinearLayout>
</ScrollView>
