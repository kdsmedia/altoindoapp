<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="&#x2190;"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@android:color/transparent"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="&#x1F4B3; ID Card Member"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- ID CARD (KTP/SIM Style) -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardIdCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@drawable/idcard_background">

                    <!-- Card Header -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:background="#003087"
                        android:padding="12dp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="36dp"
                            android:layout_height="36dp"
                            android:src="@drawable/ic_logo"
                            android:scaleType="fitCenter"
                            android:layout_marginEnd="10dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="KARTU ANGGOTA RESMI"
                                android:textSize="10sp"
                                android:textColor="#AACCFF"
                                android:letterSpacing="0.1" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ALTOMEDIA INDONESIA"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:letterSpacing="0.05" />
                        </LinearLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALTOINDO"
                            android:textSize="9sp"
                            android:textColor="#FFD700"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Card Body -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:padding="14dp">

                        <!-- Photo Area -->
                        <LinearLayout
                            android:layout_width="90dp"
                            android:layout_height="110dp"
                            android:orientation="vertical"
                            android:gravity="center"
                            android:background="#1A3A7A"
                            android:layout_marginEnd="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="&#x1F464;"
                                android:textSize="48sp"
                                android:gravity="center" />
                        </LinearLayout>

                        <!-- Info Area -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="ID ANGGOTA"
                                android:textSize="9sp"
                                android:textColor="#AACCFF" />

                            <TextView
                                android:id="@+id/tvCardMemberId"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:letterSpacing="0.1"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="NAMA LENGKAP"
                                android:textSize="9sp"
                                android:textColor="#AACCFF" />

                            <TextView
                                android:id="@+id/tvCardName"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="-"
                                android:textSize="14sp"
                                android:textStyle="bold"
                                android:textColor="#FFFFFF"
                                android:layout_marginBottom="8dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="TINGKATAN"
                                android:textSize="9sp"
                                android:textColor="#AACCFF" />

                            <TextView
                                android:id="@+id/tvCardTier"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="BRONZE"
                                android:textSize="13sp"
                                android:textStyle="bold"
                                android:textColor="#FFD700" />
                        </LinearLayout>

                        <!-- QR Code -->
                        <LinearLayout
                            android:layout_width="80dp"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:gravity="center">

                            <ImageView
                                android:id="@+id/ivCardQr"
                                android:layout_width="72dp"
                                android:layout_height="72dp"
                                android:scaleType="fitCenter"
                                android:background="#FFFFFF"
                                android:padding="4dp" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Scan QR"
                                android:textSize="8sp"
                                android:textColor="#AAAAAA"
                                android:gravity="center"
                                android:layout_marginTop="4dp" />
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Card Footer -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="#001A50"
                        android:padding="8dp"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="www.altomedia.id"
                            android:textSize="10sp"
                            android:textColor="#7EC8E3" />

                        <TextView
                            android:id="@+id/tvCardStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#x2022; AKTIF"
                            android:textSize="10sp"
                            android:textColor="#00E676"
                            android:textStyle="bold" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Status Card -->
            <androidx.cardview.widget.CardView
                android:id="@+id/cardPrintStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2744"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F4CB;"
                        android:textSize="24sp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Status Permintaan Cetak"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#7EC8E3" />

                        <TextView
                            android:id="@+id/tvPrintStatus"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Menunggu verifikasi admin"
                            android:textSize="12sp"
                            android:textColor="#FFB74D"
                            android:layout_marginTop="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Print Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2A00">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F4E6; Cetak ID Card Fisik"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#00E676"
                        android:layout_marginBottom="8dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x2022; ID Card fisik dicetak sesuai tampilan di atas&#10;&#x2022; Dikirim ke alamat profil Anda&#10;&#x2022; Berlaku sebagai tanda member resmi Altomedia&#10;&#x2022; Biaya cetak: Rp 50.000 (dipotong dari saldo)"
                        android:textSize="13sp"
                        android:textColor="#AAAAAA"
                        android:lineSpacingExtra="4dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Request Button -->
            <Button
                android:id="@+id/btnRequestPrint"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="&#x1F5A8; Cetak ID Card - Rp 50.000"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/btn_action_card"
                android:layout_marginBottom="16dp" />

            <!-- Share Button -->
            <Button
                android:id="@+id/btnShareCard"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="&#x1F4E4; Simpan / Bagikan ID Card"
                android:textColor="#AACCFF"
                android:textStyle="bold"
                android:textSize="14sp"
                android:background="@drawable/btn_action_card2"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
