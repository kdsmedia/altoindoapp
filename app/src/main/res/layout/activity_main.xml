<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_header"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingBottom="32dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ALTOINDO"
                            android:textSize="13sp"
                            android:textColor="#7EC8E3"
                            android:letterSpacing="0.2" />

                        <TextView
                            android:id="@+id/tvMemberName"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Selamat Datang"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginTop="2dp" />

                        <TextView
                            android:id="@+id/tvMemberId"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="ID: -"
                            android:textSize="12sp"
                            android:textColor="#AACCFF"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btnLogout"
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:background="@android:color/transparent"
                        android:src="@android:drawable/ic_lock_power_off"
                        android:tint="#FF6B6B" />
                </LinearLayout>

                <!-- Balance Card -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="12dp"
                    app:cardBackgroundColor="#1A2744">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="&#x1F4B3;  Saldo Wallet"
                            android:textSize="13sp"
                            android:textColor="#7EC8E3" />

                        <TextView
                            android:id="@+id/tvBalance"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Rp 0"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="#FFFFFF"
                            android:layout_marginTop="6dp" />

                        <View
                            android:layout_width="match_parent"
                            android:layout_height="1dp"
                            android:background="#2A3A5C"
                            android:layout_marginTop="12dp"
                            android:layout_marginBottom="12dp" />

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">
                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PV Personal"
                                    android:textSize="11sp"
                                    android:textColor="#AAAACC" />
                                <TextView
                                    android:id="@+id/tvPoints"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0 PV"
                                    android:textSize="16sp"
                                    android:textStyle="bold"
                                    android:textColor="#7EC8E3" />
                            </LinearLayout>

                            <TextView
                                android:id="@+id/tvProfileStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="&#x26A0; Lengkapi Profil"
                                android:textSize="11sp"
                                android:textColor="#FFB74D"
                                android:background="#2A1A00"
                                android:padding="6dp"
                                android:visibility="gone" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- Quick Actions -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="&#x26A1; Aksi Cepat"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#7EC8E3"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <LinearLayout
                    android:id="@+id/btnTransfer"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_action_card"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x1F4B8;" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Transfer" android:textSize="11sp" android:textColor="#FFFFFF"
                        android:layout_marginTop="6dp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnTopup"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_action_card"
                    android:padding="14dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x2B06;" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Top Up" android:textSize="11sp" android:textColor="#FFFFFF"
                        android:layout_marginTop="6dp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnWithdraw"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_action_card"
                    android:padding="14dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x2B07;" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tarik" android:textSize="11sp" android:textColor="#FFFFFF"
                        android:layout_marginTop="6dp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Second row actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:id="@+id/btnHistory"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_action_card2"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x1F4CB;" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Riwayat" android:textSize="11sp" android:textColor="#CCCCCC"
                        android:layout_marginTop="6dp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnNotifications"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_action_card2"
                    android:padding="14dp"
                    android:layout_marginStart="6dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x1F514;" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Notifikasi" android:textSize="11sp" android:textColor="#CCCCCC"
                        android:layout_marginTop="6dp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnSettings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_action_card2"
                    android:padding="14dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x2699;" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Info" android:textSize="11sp" android:textColor="#CCCCCC"
                        android:layout_marginTop="6dp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Third row: Rank + ID Card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="10dp">

                <LinearLayout
                    android:id="@+id/btnRanking"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_action_card"
                    android:padding="14dp"
                    android:layout_marginEnd="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x1F3C6;" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Ranking" android:textSize="11sp" android:textColor="#FFFFFF"
                        android:layout_marginTop="6dp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btnIdCard"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="@drawable/btn_action_card"
                    android:padding="14dp"
                    android:layout_marginStart="6dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="&#x1F4B3;" android:textSize="28sp" />
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="ID Card" android:textSize="11sp" android:textColor="#FFFFFF"
                        android:layout_marginTop="6dp" android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Bonus Promo Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="8dp"
                app:cardBackgroundColor="#0A2A1A">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:padding="16dp"
                    android:gravity="center_vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F31F;"
                        android:textSize="28sp"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Klaim Bonus Harian"
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:textColor="#00E676" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tonton video, dapatkan bonus Rp.10 - Rp.100"
                            android:textSize="11sp"
                            android:textColor="#AAAAAA"
                            android:layout_marginTop="2dp" />
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <View android:layout_width="match_parent" android:layout_height="16dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <include layout="@layout/layout_bottom_nav" />

</LinearLayout>
