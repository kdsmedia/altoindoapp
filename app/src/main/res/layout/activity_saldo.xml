<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/gradient_header"
                android:orientation="vertical"
                android:padding="20dp"
                android:paddingBottom="28dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="&#x1F4B0; Saldo Saya"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Kelola saldo dan transaksi Anda"
                    android:textSize="13sp"
                    android:textColor="#AACCFF"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- Balance Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="16dp"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardElevation="12dp"
                app:cardBackgroundColor="#1A2744">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp"
                    android:gravity="center">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Saldo Wallet"
                        android:textSize="14sp"
                        android:textColor="#7EC8E3" />

                    <TextView
                        android:id="@+id/tvSaldoBalance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 0"
                        android:textSize="32sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="8dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="16dp"
                        android:gravity="center">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PV Personal"
                                android:textSize="11sp"
                                android:textColor="#AAAACC" />
                            <TextView
                                android:id="@+id/tvSaldoPvPersonal"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 PV"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#7EC8E3" />
                        </LinearLayout>

                        <View
                            android:layout_width="1dp"
                            android:layout_height="40dp"
                            android:background="#2A3A5C" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:gravity="center">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PV Group"
                                android:textSize="11sp"
                                android:textColor="#AAAACC" />
                            <TextView
                                android:id="@+id/tvSaldoPvGroup"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0 PV"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="#00E676" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:layout_marginTop="8dp">

                <Button
                    android:id="@+id/btnSaldoTopup"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="&#x2B06; Top Up"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_action_card"
                    android:layout_marginEnd="8dp" />

                <Button
                    android:id="@+id/btnSaldoWithdraw"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="&#x2B07; Tarik Saldo"
                    android:textColor="#FFFFFF"
                    android:textStyle="bold"
                    android:background="@drawable/btn_action_card2"
                    android:layout_marginStart="8dp" />
            </LinearLayout>

            <Button
                android:id="@+id/btnSaldoTransfer"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="&#x1F4B8; Transfer ke Member"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:background="@drawable/gradient_card"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp" />

            <Button
                android:id="@+id/btnSaldoHistory"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="&#x1F4CB; Riwayat Transaksi"
                android:textColor="#AACCFF"
                android:textStyle="bold"
                android:background="@drawable/btn_action_card2"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                android:layout_marginTop="10dp" />

            <View android:layout_width="match_parent" android:layout_height="24dp" />
        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <include layout="@layout/layout_bottom_nav" />

</LinearLayout>
