<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TopUp Saldo"
            android:textSize="22sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="16dp"
            android:weightSum="3">

            <Button
                android:id="@+id/btn_nominal_10k"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10rb" />

            <Button
                android:id="@+id/btn_nominal_50k"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="50rb" />

            <Button
                android:id="@+id/btn_nominal_100k"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="100rb" />
        </LinearLayout>

        <EditText
            android:id="@+id/et_amount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="Atau ketik nominal lain..."
            android:inputType="number" />

        <EditText
            android:id="@+id/et_sender_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Nama (opsional)" />

        <EditText
            android:id="@+id/et_sender_message"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Pesan (opsional)"
            android:inputType="text" />

        <Button
            android:id="@+id/btn_generate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="TOPUP SALDO" />

        <LinearLayout
            android:id="@+id/qr_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:paddingTop="20dp">

            <TextView
                android:id="@+id/tv_pay_timer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Selesaikan dalam 03:00"
                android:textSize="12sp"
                android:textColor="#e74c3c"
                android:textStyle="bold" />

            <ImageView
                android:id="@+id/iv_qr"
                android:layout_width="200dp"
                android:layout_height="200dp"
                android:layout_marginTop="12dp"
                android:layout_gravity="center" />

            <TextView
                android:id="@+id/tv_total_display"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="18sp"
                android:textStyle="bold"
                android:layout_marginTop="12dp" />

            <TextView
                android:id="@+id/tv_trx_id"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TRX-ID: "
                android:textSize="12sp"
                android:textColor="#777"
                android:layout_marginTop="6dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Cara Pembayaran:\n1. Klik tombol \"SIMPAN QR CODE\".\n2. Buka aplikasi BCA, Dana, Gojek, dll.\n3. Pilih menu Scan / QRIS.\n4. Pilih ikon Galeri dan pilih gambar tadi.\n5. Nominal muncul otomatis, bayar sekarang."
                android:textSize="14sp"
                android:layout_marginTop="12dp" />

            <Button
                android:id="@+id/btn_save_qr"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="💾 SIMPAN QR CODE" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
