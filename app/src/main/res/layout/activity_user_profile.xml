<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0F1E">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/gradient_header"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="&#x2190;"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:background="@android:color/transparent"
            android:layout_marginEnd="12dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="&#x270F; Edit Profil"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2744">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ID Member"
                        android:textSize="11sp"
                        android:textColor="#7EC8E3" />

                    <TextView
                        android:id="@+id/tvMemberId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Email"
                        android:textSize="11sp"
                        android:textColor="#7EC8E3" />

                    <TextView
                        android:id="@+id/tvEmail"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="14sp"
                        android:textColor="#CCCCCC" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Personal Info Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2744">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F464; Data Pribadi"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#7EC8E3"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Lengkap *"
                        android:textSize="12sp"
                        android:textColor="#AACCFF" />

                    <EditText
                        android:id="@+id/etFullName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nama Lengkap"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/btn_action_card2"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"
                        android:inputType="textPersonName" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="No. Telepon *"
                        android:textSize="12sp"
                        android:textColor="#AACCFF" />

                    <EditText
                        android:id="@+id/etPhone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="No. Telepon"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/btn_action_card2"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"
                        android:inputType="phone" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Alamat Lengkap (untuk pengiriman) *"
                        android:textSize="12sp"
                        android:textColor="#AACCFF" />

                    <EditText
                        android:id="@+id/etAddress"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Jalan, Kelurahan, Kecamatan, Kota, Provinsi, Kode Pos"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/btn_action_card2"
                        android:padding="12dp"
                        android:minLines="3"
                        android:gravity="top"
                        android:inputType="textMultiLine|textPostalAddress" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Dropship Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2744">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F4E6; Nama Dropship (opsional)"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#7EC8E3"
                        android:layout_marginBottom="6dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama yang akan tercantum sebagai pengirim saat pembelian produk"
                        android:textSize="11sp"
                        android:textColor="#AAAAAA"
                        android:layout_marginBottom="10dp" />

                    <EditText
                        android:id="@+id/etDropshipName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nama pengirim dropship"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/btn_action_card2"
                        android:padding="12dp"
                        android:inputType="textPersonName" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bank Account Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="6dp"
                app:cardBackgroundColor="#1A2744">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="&#x1F3E6; Data Rekening Bank *"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="#7EC8E3"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipe Rekening"
                        android:textSize="12sp"
                        android:textColor="#AACCFF" />

                    <Spinner
                        android:id="@+id/spinnerAccountType"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="@drawable/btn_action_card2"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Bank/E-Wallet *"
                        android:textSize="12sp"
                        android:textColor="#AACCFF" />

                    <EditText
                        android:id="@+id/etAccountName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Contoh: BCA, BRI, OVO, GoPay"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/btn_action_card2"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nama Pemilik Rekening *"
                        android:textSize="12sp"
                        android:textColor="#AACCFF" />

                    <EditText
                        android:id="@+id/etAccountOwner"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nama sesuai rekening"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/btn_action_card2"
                        android:padding="12dp"
                        android:layout_marginBottom="12dp"
                        android:inputType="textPersonName" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Nomor Rekening *"
                        android:textSize="12sp"
                        android:textColor="#AACCFF" />

                    <EditText
                        android:id="@+id/etAccountNumber"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Nomor rekening/wallet"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#666666"
                        android:background="@drawable/btn_action_card2"
                        android:padding="12dp"
                        android:inputType="number" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="* Wajib diisi untuk dapat melakukan transaksi"
                android:textSize="11sp"
                android:textColor="#FFB74D"
                android:layout_marginBottom="16dp" />

            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="&#x1F4BE; Simpan Profil"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:textSize="15sp"
                android:background="@drawable/btn_action_card"
                android:layout_marginBottom="32dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
