<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="6dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="6dp"
    app:cardBackgroundColor="#1A2744">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="14dp"
        android:gravity="center_vertical">

        <!-- Rank Number -->
        <TextView
            android:id="@+id/tvRankNumber"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:gravity="center"
            android:text="1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="#FFD700"
            android:background="@drawable/btn_action_card"
            android:layout_marginEnd="14dp" />

        <!-- Member Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvRankName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nama Member"
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tvRankMemberId"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ID: -"
                android:textSize="12sp"
                android:textColor="#AAAACC"
                android:layout_marginTop="2dp" />

            <TextView
                android:id="@+id/tvRankTier"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Bronze"
                android:textSize="11sp"
                android:textColor="#CD7F32"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <!-- Value -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <TextView
                android:id="@+id/tvRankValue"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#00E676"
                android:gravity="end" />

            <TextView
                android:id="@+id/tvRankLabel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Saldo"
                android:textSize="10sp"
                android:textColor="#AAAAAA"
                android:gravity="end" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
